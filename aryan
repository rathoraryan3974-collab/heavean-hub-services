<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Heaven Hub - Rooms Available for Rent</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            line-height: 1.6;
            color: #333;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        header {
            background: rgba(255, 255, 255, 0.95);
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            text-align: center;
            margin-bottom: 30px;
        }

        .logo {
            font-size: 2.5em;
            font-weight: bold;
            color: #667eea;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
        }

        .tagline {
            color: #666;
            font-size: 1.2em;
        }

        .hero {
            background: rgba(255, 255, 255, 0.95);
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.2);
            text-align: center;
            margin-bottom: 40px;
        }

        .hero h1 {
            color: #333;
            font-size: 2.8em;
            margin-bottom: 20px;
        }

        .features {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .feature-card {
            background: rgba(255, 255, 255, 0.9);
            padding: 30px;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: transform 0.3s ease;
        }

        .feature-card:hover {
            transform: translateY(-10px);
        }

        .feature-icon {
            font-size: 3em;
            margin-bottom: 15px;
        }

        .rooms-section {
            background: rgba(255, 255, 255, 0.95);
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.2);
            margin-bottom: 40px;
        }

        .room-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-top: 30px;
        }

        .room-card {
            background: white;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            border-left: 5px solid #667eea;
            transition: all 0.3s ease;
        }

        .room-card:hover {
            box-shadow: 0 20px 50px rgba(0,0,0,0.2);
        }

        .room-price {
            font-size: 2em;
            color: #28a745;
            font-weight: bold;
            margin-bottom: 15px;
        }

        .form-section {
            background: rgba(255, 255, 255, 0.95);
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.2);
        }

        .form-container {
            max-width: 600px;
            margin: 0 auto;
        }

        .form-group {
            margin-bottom: 25px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
            color: #333;
        }

        input, select, textarea {
            width: 100%;
            padding: 15px;
            border: 2px solid #e1e5e9;
            border-radius: 10px;
            font-size: 16px;
            transition: border-color 0.3s ease;
        }

        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 10px rgba(102, 126, 234, 0.3);
        }

        textarea {
            resize: vertical;
            min-height: 120px;
        }

        .btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 18px 40px;
            border: none;
            border-radius: 10px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.3s ease;
            width: 100%;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
        }

        .contact-info {
            text-align: center;
            background: rgba(255, 255, 255, 0.9);
            padding: 30px;
            border-radius: 15px;
            margin-top: 30px;
        }

        .contact-item {
            display: inline-block;
            margin: 0 20px;
            font-size: 1.2em;
        }

        .contact-icon {
            font-size: 1.5em;
            margin-right: 10px;
        }

        @media (max-width: 768px) {
            .hero h1 {
                font-size: 2em;
            }
            
            .logo {
                font-size: 2em;
            }
            
            .room-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <header>
            <h1 class="logo">🌟 Heaven Hub 🌟</h1>
            <p class="tagline">Your Perfect Home Away From Home</p>
        </header>

        <!-- Hero Section -->
        <section class="hero">
            <h1>Premium Rooms Available for Rent</h1>
            <p style="font-size: 1.3em; color: #666; margin-bottom: 30px;">
                Comfortable, secure, and fully equipped rooms with modern amenities
            </p>
        </section>

        <!-- Features Section -->
        <section class="features">
            <div class="feature-card">
                <div class="feature-icon">⚡</div>
                <h3>24/7 Generator</h3>
                <p>Never worry about power outages with our reliable backup generator</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📶</div>
                <h3>High-Speed WiFi</h3>
                <p>Unlimited internet access for work, study, and entertainment</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🔒</div>
                <h3>24/7 Security</h3>
                <p>Professional security personnel and CCTV surveillance</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🛏️</div>
                <h3>Fully Furnished</h3>
                <p>Move-in ready with all essential furniture and appliances</p>
            </div>
        </section>

        <!-- Rooms Section -->
        <section class="rooms-section">
            <h2 style="text-align: center; font-size: 2.5em; margin-bottom: 30px; color: #333;">Available Rooms</h2>
            <div class="room-grid">
                <div class="room-card">
                    <div class="room-price">₦25,000/month</div>
                    <h3>Standard Single Room</h3>
                    <ul style="list-style: none; padding: 0;">
                        <li>✓ Single bed with mattress</li>
                        <li>✓ Wardrobe & study table</li>
                        <li>✓ Fan & lighting</li>
                        <li>✓ Shared bathroom</li>
                    </ul>
                </div>
                <div class="room-card">
                    <div class="room-price">₦35,000/month</div>
                    <h3>Deluxe Single Room</h3>
                    <ul style="list-style: none; padding: 0;">
                        <li>✓ En-suite bathroom</li>
                        <li>✓ Air conditioner</li>
                        <li>✓ King-size bed</li>
                        <li>✓ Smart TV</li>
                    </ul>
                </div>
                <div class="room-card">
                    <div class="room-price">₦45,000/month</div>
                    <h3>Executive Suite</h3>
                    <ul style="list-style: none; padding: 0;">
                        <li>✓ Private bathroom & kitchenette</li>
                        <li>✓ AC & refrigerator</li>
                        <li>✓ 42" Smart TV</li>
                        <li>✓ Balcony access</li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Booking Form -->
        <section class="form-section">
            <h2 style="text-align: center; font-size: 2.5em; margin-bottom: 30px; color: #333;">Book Your Room Today</h2>
            <form class="form-container" id="bookingForm">
                <div class="form-group">
                    <label for="name">Full Name *</label>
                    <input type="text" id="name" name="name" required>
                </div>
                
                <div class="form-group">
                    <label for="email">Email Address *</label>
                    <input type="email" id="email" name="email" required>
                </div>
                
                <div class="form-group">
                    <label for="phone">Phone Number *</label>
                    <input type="tel" id="phone" name="phone" required>
                </div>
                
                <div class="form-group">
                    <label for="roomType">Room Type *</label>
                    <select id="roomType" name="roomType" required>
                        <option value="">Select Room Type</option>
                        <option value="standard">Standard Single (₦25,000)</option>
                        <option value="deluxe">Deluxe Single (₦35,000)</option>
                        <option value="executive">Executive Suite (₦45,000)</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="moveInDate">Preferred Move-in Date *</label>
                    <input type="date" id="moveInDate" name="moveInDate" required>
                </div>
                
                <div class="form-group">
                    <label for="message">Additional Requirements</label>
                    <textarea id="message" name="message" placeholder="Any special requirements or questions?"></textarea>
                </div>
                
                <button type="submit" class="btn">Submit Booking Request</button>
            </form>
        </section>

        <!-- Contact Info -->
        <div class="contact-info">
            <h3 style="margin-bottom: 20px; color: #333;">Contact Us</h3>
            <div class="contact-item">
                <span class="contact-icon">📞</span> +234 800 123 4567
            </div>
            <div class="contact-item">
                <span class="contact-icon">✉️</span> info@heavenhub.com
            </div>
            <div class="contact-item">
                <span class="contact-icon">📍</span> 123 Heaven Street, Lagos
            </div>
        </div>
    </div>

    <script>
        // Form submission handler
        document.getElementById('bookingForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            // Simple form validation
            const formData = new FormData(this);
            const name = document.getElementById('name').value;
            
            // Simulate form submission
            alert(`Thank you, ${name}! Your booking request has been submitted successfully. We will contact you within 24 hours.`);
            
            // Reset form
            this.reset();
        });

        // Set minimum date to today
        document.getElementById('moveInDate').min = new Date().toISOString().split('T')[0];
    </script>
</body>
</html>
